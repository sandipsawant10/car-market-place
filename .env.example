# ==============================
# Car Market - Environment Setup
# ==============================
# Copy this file to .env and fill in real values.
# Do not commit your real .env file.

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key

# Neon Postgres
VITE_NEON_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require

# Sendbird
# Preferred key used by service layer:
VITE_SENDBIRD_APP_ID=your_sendbird_app_id
# Fallback key used in some components:
VITE_APPLICATION_ID=your_sendbird_application_id
VITE_SENDBIRD_MASTER_API_TOKEN=your_sendbird_platform_api_token
VITE_SENDBIRD_API_TOKEN=your_sendbird_api_token
VITE_ACCESS_KEY=your_sendbird_access_key

# Cloudinary (unsigned upload)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
